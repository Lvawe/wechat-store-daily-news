# ===== WeWe RSS 环境变量模板 =====
# 复制本文件为 .env 并按需修改：  cp .env.example .env

# MySQL root 密码（自定义一个强密码）
DB_ROOT_PASSWORD=wewe_rss_pwd

# 后台管理登录 / 接口授权码（务必改成你自己的私密值）
# 注意：/feeds 订阅链接本身不需要这个码，仅后台管理与受保护接口需要
AUTH_CODE=please-change-me

# 服务对外暴露端口（宿主机端口）
PORT=4000

# 对外访问地址，用于拼接完整 RSS 链接
# 本机调试用 http://localhost:4000
# 部署到服务器请改成 http://服务器IP:4000 或 https://你的域名
SERVER_ORIGIN_URL=http://localhost:4000

# 定时抓取订阅源的 Cron（默认每天 05:35 和 17:35）
CRON_EXPRESSION=35 5,17 * * *
